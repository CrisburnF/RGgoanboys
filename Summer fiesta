<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Goan Food & Cultural Festival 2026 | Reading Goan Boys</title>
    <meta name="description" content="Reading Goan Boys present the Goan Food & Cultural Festival — 8 August 2026. Live brass bands, DJ sets, authentic street food, cultural performances and more.">
    <meta property="og:title" content="Goan Food & Cultural Festival 2026 — 8 August, Reading">
    <meta property="og:description" content="Live bands, DJs, authentic Goan street food, cultural performances and family activities. Reading's biggest Goan event of the year.">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;900&display=swap" rel="stylesheet">

    <style>
        :root {
            --goan-gold: #FFD700;
            --deep-navy: #050A18;
            --accent-blue: #0dcaf0;
        }

        html { scroll-padding-top: 100px; }

        body {
            background-color: var(--deep-navy);
            color: #ffffff;
            font-family: 'Outfit', sans-serif;
            overflow-x: hidden;
        }

        .navbar {
            background: rgba(5, 10, 24, 0.95) !important;
            backdrop-filter: blur(15px);
            border-bottom: 1px solid rgba(255, 215, 0, 0.15);
            padding: 1rem 0;
        }

        .navbar-brand {
            font-weight: 900;
            letter-spacing: 1.5px;
            color: var(--goan-gold) !important;
            font-size: 1.3rem;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .nav-logo {
            height: 70px;
            width: 70px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--goan-gold);
            background-color: #fff;
        }

        /* Hero */
        .event-hero {
            min-height: 70vh;
            background: linear-gradient(rgba(5, 10, 24, 0.6), rgba(5, 10, 24, 0.97)), 
                        linear-gradient(135deg, #1a6b8a, #2d9e6b, #c8860a);
            display: flex;
            align-items: flex-end;
            padding-bottom: 80px;
            padding-top: 120px;
            position: relative;
            overflow: hidden;
        }

        .event-hero::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: url('./images/Food___Cullure.png') center/contain no-repeat;
            opacity: 0.08;
            pointer-events: none;
        }

        .event-badge {
            display: inline-block;
            background: linear-gradient(45deg, #FFD700, #FDB931);
            color: #000;
            font-weight: 900;
            font-size: 0.8rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 8px 20px;
            border-radius: 50px;
            margin-bottom: 20px;
        }

        .event-title {
            font-size: clamp(2.5rem, 7vw, 5.5rem);
            font-weight: 900;
            line-height: 1.05;
            text-transform: uppercase;
        }

        .info-pill {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 50px;
            padding: 10px 20px;
            font-size: 0.9rem;
            font-weight: 600;
            margin: 6px 6px 6px 0;
        }

        .info-pill i { color: var(--goan-gold); }

        /* Section cards */
        .detail-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 20px;
            padding: 35px;
            height: 100%;
            transition: border-color 0.3s;
        }

        .detail-card:hover {
            border-color: rgba(255,215,0,0.3);
        }

        .detail-card h4 {
            color: var(--goan-gold);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 1rem;
            margin-bottom: 20px;
        }

        .detail-card .icon-lg {
            font-size: 2rem;
            color: var(--goan-gold);
            margin-bottom: 15px;
            display: block;
        }

        /* Coming soon placeholder */
        .coming-soon-block {
            background: rgba(255,215,0,0.04);
            border: 1px dashed rgba(255,215,0,0.25);
            border-radius: 16px;
            padding: 30px;
            text-align: center;
        }

        .coming-soon-block .label {
            display: inline-block;
            background: rgba(255,215,0,0.12);
            color: var(--goan-gold);
            font-size: 0.75rem;
            font-weight: 800;
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 5px 14px;
            border-radius: 50px;
            margin-bottom: 12px;
        }

        /* Countdown */
        .countdown-wrap {
            background: linear-gradient(135deg, rgba(255,215,0,0.08), rgba(13,202,240,0.05));
            border: 1px solid rgba(255,215,0,0.2);
            border-radius: 20px;
            padding: 40px;
            text-align: center;
        }

        .countdown-unit {
            padding: 0 20px;
        }

        .countdown-number {
            font-size: clamp(2.5rem, 6vw, 4rem);
            font-weight: 900;
            color: var(--goan-gold);
            line-height: 1;
            display: block;
        }

        .countdown-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            opacity: 0.5;
            font-weight: 700;
        }

        .countdown-divider {
            font-size: 2.5rem;
            font-weight: 900;
            color: var(--goan-gold);
            opacity: 0.4;
            align-self: flex-start;
            padding-top: 5px;
        }

        /* Buttons */
        .btn-gold {
            background: linear-gradient(45deg, #FFD700, #FDB931);
            color: #000 !important;
            font-weight: 800;
            border: none;
            padding: 14px 40px;
            border-radius: 50px;
            transition: 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 0.9rem;
            text-decoration: none;
            display: inline-block;
        }

        .btn-gold:hover {
            box-shadow: 0 0 25px rgba(255, 215, 0, 0.4);
            transform: translateY(-2px);
        }

        .btn-outline-gold {
            border: 2px solid var(--goan-gold);
            color: var(--goan-gold) !important;
            font-weight: 800;
            padding: 12px 35px;
            border-radius: 50px;
            transition: 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 0.9rem;
            text-decoration: none;
            display: inline-block;
            background: transparent;
        }

        .btn-outline-gold:hover {
            background: var(--goan-gold);
            color: #000 !important;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: rgba(255,255,255,0.5);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: color 0.3s;
            margin-bottom: 30px;
        }

        .back-link:hover { color: var(--goan-gold); }

        /* Map placeholder */
        .map-placeholder {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 16px;
            padding: 40px;
            text-align: center;
            min-height: 200px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        footer {
            background: #020305;
            padding: 50px 0 30px;
            border-top: 1px solid rgba(255, 215, 0, 0.1);
            text-align: center;
        }

        .footer-logo {
            height: 80px;
            width: 80px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--goan-gold);
            background-color: #fff;
            margin-bottom: 15px;
        }
    </style>
</head>
<body>

